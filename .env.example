# Copy this file to .env and set your real values.

# SMTP settings (Gmail example)
CONTACT_SMTP_HOST=smtp.gmail.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_ENCRYPTION=tls
CONTACT_SMTP_USER=your-gmail@gmail.com
CONTACT_SMTP_APP_PASSWORD=your-16-char-app-password
# Optional: set true to show SMTP errors directly in form response while testing
CONTACT_SMTP_DEBUG=false

# Recipient address for contact form submissions
CONTACT_TO_EMAIL=your-gmail@gmail.com

# Sender identity shown in the email
CONTACT_FROM_EMAIL=your-gmail@gmail.com
CONTACT_FROM_NAME=M. Salman Naeem Website

# Prefix used in email subject lines
CONTACT_SUBJECT_PREFIX=Portfolio Contact